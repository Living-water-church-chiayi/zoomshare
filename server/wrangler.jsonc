{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lingxiu-presence",
  "main": "src/index.mjs",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
